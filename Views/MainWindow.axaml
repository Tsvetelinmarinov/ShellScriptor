<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avaEdit="https://github.com/avaloniaui/avaloniaedit"
        xmlns:vm="using:ShellScriptor.ViewModels"
        Width="1200"
        Height="650"
        x:Class="ShellScriptor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Background="{Binding Background}"
        Icon="avares://ShellScriptor/Assets/scriptor.ico"
        Title="Shell Scriptor"
        KeyDown="F11KeyPressed">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    
    <Window.Styles>
        <Style Selector="Button.icon-btn">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.5"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.5"/>
                </Transitions>
            </Setter>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        
        <Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Opacity" Value="1.2"/>
            <Setter Property="RenderTransform" Value="scale(1.1)"/>
        </Style>
        
        <Style Selector="Button.icon-btn:pressed">
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="RenderTransform" Value="scale(0.5)"/>
        </Style>
        
        <Style Selector="Button.icon-btn">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Styles>
    
    <DockPanel>
        <StackPanel DockPanel.Dock="Top"
                    Spacing="20"
                    Margin="50, 10, 25, 10"
                    Orientation="Horizontal">
            <Button Background="Transparent"
                    BorderThickness="0"
                    ToolTip.Tip="Open file"
                    Click="LoadFile"
                    Classes="icon-btn">
                <Image Width="25"
                       Height="25"
                       Source="avares://ShellScriptor/Assets/icons8-script-48.png">
                </Image>
            </Button>
            <Button Background="Transparent"
                    BorderThickness="0"
                    ToolTip.Tip="Save file"
                    Click="ExportFile"
                    Classes="icon-btn">
                <Image Width="25"
                       Height="25"
                       Source="avares://ShellScriptor/Assets/save.png">
                </Image>
            </Button>
            <Button Background="Transparent"
                    BorderThickness="0"
                    ToolTip.Tip="Change font size"
                    Click="OpenFontSettings"
                    Classes="icon-btn">
                <Image Width="25"
                       Height="25"
                       Source="avares://ShellScriptor/Assets/icons8-font-48.png">
                </Image>
            </Button>
            <Rectangle Width="1"
                       Height="23"
                       Fill="DarkSlateBlue">
            </Rectangle>
            <Button Background="Transparent"
                    BorderThickness="0"
                    ToolTip.Tip="Execute"
                    Click="Execute"
                    Classes="icon-btn execute-btn">
                <Image Width="23"
                       Height="23"
                       Source="avares://ShellScriptor/Assets/icons8-play-48.png">
                </Image>
            </Button>
        </StackPanel>
        <avaEdit:TextEditor Document="{Binding Document, Mode=TwoWay}"
                            Background="{Binding Background}"
                            FontFamily="Fira Code"
                            Foreground="GhostWhite"
                            FontSize="{Binding FontSizе}"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Visible"
                            ShowLineNumbers="True"
                            LineNumbersForeground="IndianRed"
                            LineNumbersMargin="10, 0"
                            BorderThickness="0,1,0,0"
                            BorderBrush="IndianRed"
                            x:Name="Editor">
        </avaEdit:TextEditor>
    </DockPanel>
</Window>